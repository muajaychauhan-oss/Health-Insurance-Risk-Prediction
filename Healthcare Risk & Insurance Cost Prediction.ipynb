     ]
    }
   ],
   "source": [
    "# Feature Importance (From Random Forest )\n",
    "importances = pd.Series(rf_model.feature_importances_, index=X.columns)\n",
    "print(\"\\nTop Factors affecting Health Claims:\")\n",
    "print(importances.sort_values(ascending=False))"
   ]
  },
